{
  "name": "@tombatossals/chords-db",
  "version": "0.6.0",
  "description": "Instrument Chords Database",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js src",
    "stdout": "node src/generate.js",
    "build": "node src/generate.js json",
    "precommit": "lint-staged",
    "prepublish": "npm run build",
    "prettier": "prettier --single-quote --write \"src/**/*.{js,jsx}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tombatossals/chords-db.git"
  },
  "keywords": [
    "music",
    "node",
    "javascript"
  ],
  "author": {
    "name": "gerardo leon"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tombatossals/chords-db/issues"
  },
  "homepage": "https://github.com/tombatossals/chords-db#readme",
  "devDependencies": {
    "husky": "^4.2.5",
    "jest": "^30.2.0",
    "lint-staged": "^10.1.7",
    "prettier": "^2.0.5"
  },
  "jest": {
    "verbose": false,
    "bail": true
  },
  "lint-staged": {
    "src/**/*.{js,jsx,json,css}": [
      "prettier --single-quote --write",
      "git add"
    ]
  }
}
